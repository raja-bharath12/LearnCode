# LearnCode — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/learncode
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/learncode

# JWT Secret (change this to a long random string in production!)
JWT_SECRET=learncode_super_secret_key_change_me_in_production_123456

# CORS Origins (comma separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
